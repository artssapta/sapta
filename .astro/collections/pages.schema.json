{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "blocks": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "const": "hero"
              },
              "title": {
                "type": "string"
              },
              "subtitle": {
                "type": "string"
              },
              "color": {
                "type": "string"
              }
            },
            "required": [
              "type",
              "title"
            ]
          },
          {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "const": "about"
              },
              "title": {
                "type": "string"
              },
              "text": {
                "type": "string"
              },
              "image": {
                "type": "string"
              },
              "imageSide": {
                "type": "string",
                "enum": [
                  "left",
                  "right"
                ]
              }
            },
            "required": [
              "type",
              "title",
              "text",
              "image"
            ]
          },
          {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "const": "events"
              },
              "title": {
                "type": "string"
              },
              "flyerImage": {
                "type": "string"
              },
              "color": {
                "type": "string"
              }
            },
            "required": [
              "type",
              "title",
              "flyerImage"
            ]
          },
          {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "const": "team-grid"
              },
              "title": {
                "type": "string"
              }
            },
            "required": [
              "type"
            ]
          },
          {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "const": "google-form"
              },
              "url": {
                "type": "string"
              },
              "height": {
                "type": "string"
              }
            },
            "required": [
              "type",
              "url"
            ]
          },
          {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "const": "text"
              },
              "heading": {
                "type": "string"
              },
              "text": {
                "type": "string"
              },
              "alignment": {
                "type": "string",
                "enum": [
                  "left",
                  "center",
                  "right"
                ]
              }
            },
            "required": [
              "type"
            ]
          },
          {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "const": "youtube"
              },
              "title": {
                "type": "string"
              },
              "videoUrl": {
                "type": "string"
              }
            },
            "required": [
              "type"
            ]
          },
          {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "const": "gallery"
              },
              "title": {
                "type": "string"
              },
              "images": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "src": {
                      "type": "string"
                    },
                    "alt": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "src"
                  ]
                }
              }
            },
            "required": [
              "type"
            ]
          }
        ]
      }
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "blocks"
  ]
}