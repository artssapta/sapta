---
const { heading, text, alignment = "center" } = Astro.props;
---
<div class="text-block reveal" style={`text-align: ${alignment};`}>
    {heading && <h2>{heading}</h2>}
    <p>{text}</p>
</div>

<style>
    .text-block { max-width: 800px; margin: 25px auto; padding: 0 20px; }
    h2 { font-family: 'Lora', serif; font-size: 2.2rem; font-weight: 400; margin-bottom: 15px; color: #1e6c93; }
    p { font-family: 'Gentium Basic', serif; font-size: 1.15rem; line-height: 1.6667; color: #212121; }
</style>
