---
const { title, events = [], color = "#2A7396" } = Astro.props;
const resolvePath = (p) => p && p.startsWith('/') ? `${import.meta.env.BASE_URL.replace(/\/$/, '')}${p}` : p;
const bgImage = resolvePath("/assets/hero_music_banner.png");
---
<section class="events-section">
    <div class="events-hero" style={`background-image: url(${bgImage}); background-color: ${color};`}>
        <div class="events-hero-overlay"></div>
        <div class="events-hero-content">
            <h1>{title || "Events"}</h1>
        </div>
    </div>

    {events.length > 0 && (
        <div class="events-nav-container">
            <div class="events-tabs-nav">
                {events.map((event, index) => (
                    <button 
                        class={`event-tab-btn ${index === 0 ? 'active' : ''}`}
                        data-event-id={event.id}
                    >
                        {event.title}
                    </button>
                ))}
            </div>
        </div>
    )}

    <div class="container">
        {events.map((event, index) => (
            <div 
                id={`panel-${event.id}`} 
                class={`event-panel ${index === 0 ? 'active' : ''}`}
            >
                <div class="event-main-grid">
                    {/* Left Column - Flyer & Information */}
                    <div class="event-info-col">
                        <div class="flyer-card">
                            <div class="flyer-card-inner">
                                <img src={resolvePath(event.flyerImage)} alt={`${event.title} Flyer`} />
                            </div>
                        </div>

                        <div class="details-text-card">
                            <h2 class="event-title">{event.title}</h2>
                            {event.subtitle && <p class="event-subtitle">{event.subtitle}</p>}
                            
                            <div class="event-metadata">
                                <div class="meta-item">
                                    <div class="icon-wrapper">
                                        <svg class="meta-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                                            <line x1="16" y1="2" x2="16" y2="6"></line>
                                            <line x1="8" y1="2" x2="8" y2="6"></line>
                                            <line x1="3" y1="10" x2="21" y2="10"></line>
                                        </svg>
                                    </div>
                                    <div class="meta-text">
                                        <span class="meta-label">Date</span>
                                        <span class="meta-val">{event.date}</span>
                                    </div>
                                </div>
                                
                                {event.time && (
                                    <div class="meta-item">
                                        <div class="icon-wrapper">
                                            <svg class="meta-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                <circle cx="12" cy="12" r="10"></circle>
                                                <polyline points="12 6 12 12 16 14"></polyline>
                                            </svg>
                                        </div>
                                        <div class="meta-text">
                                            <span class="meta-label">Time</span>
                                            <span class="meta-val">{event.time}</span>
                                        </div>
                                    </div>
                                )}

                                {event.location && (
                                    <div class="meta-item">
                                        <div class="icon-wrapper">
                                            <svg class="meta-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                                                <circle cx="12" cy="10" r="3"></circle>
                                            </svg>
                                        </div>
                                        <div class="meta-text">
                                            <span class="meta-label">Venue</span>
                                            <span class="meta-val">{event.location}</span>
                                        </div>
                                    </div>
                                )}
                            </div>

                            {event.description && (
                                <div class="event-description">
                                    <p>{event.description}</p>
                                </div>
                            )}
                        </div>
                    </div>

                    {/* Right Column - Media (Videos & Photos) */}
                    <div class="event-media-col">
                        {/* Videos */}
                        {event.videos && event.videos.length > 0 && (
                            <div class="event-videos-section">
                                <h3 class="media-title">Videos & Performances</h3>
                                <div class="videos-grid">
                                    {event.videos.map((vid) => {
                                        const isLocal = vid.videoUrl.endsWith('.mp4') || vid.videoUrl.endsWith('.MP4') || vid.videoUrl.startsWith('/assets/');
                                        if (isLocal) {
                                            return (
                                                <div class="video-card">
                                                    <div class="video-wrapper">
                                                        <video controls preload="metadata" class="local-video">
                                                            <source src={resolvePath(vid.videoUrl)} type="video/mp4" />
                                                            Your browser does not support the video tag.
                                                        </video>
                                                    </div>
                                                    {vid.title && <p class="video-caption">{vid.title}</p>}
                                                </div>
                                            );
                                        }

                                        const videoId = vid.videoUrl.includes('v=') 
                                            ? vid.videoUrl.split('v=')[1].split('&')[0] 
                                            : vid.videoUrl.split('/').pop();
                                        return (
                                            <div class="video-card">
                                                <div class="iframe-wrapper">
                                                    <iframe 
                                                        src={`https://www.youtube.com/embed/${videoId}`} 
                                                        title={vid.title || "YouTube video player"} 
                                                        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" 
                                                        allowfullscreen>
                                                    </iframe>
                                                </div>
                                                {vid.title && <p class="video-caption">{vid.title}</p>}
                                            </div>
                                        );
                                    })}
                                </div>
                            </div>
                        )}

                        {/* Gallery */}
                        {event.gallery && event.gallery.length > 0 && (
                            <div class="event-gallery-section">
                                <h3 class="media-title">Event Gallery</h3>
                                <p class="gallery-instruction">Click on any image to view in full screen</p>
                                <div class="photo-grid-scroll">
                                    <div class="photo-grid">
                                        {event.gallery.map((img) => (
                                            <div class="photo-card">
                                                <div class="photo-card-inner">
                                                    <img 
                                                        src={resolvePath(img.src)} 
                                                        alt={img.alt || "Event gallery photo"} 
                                                    />
                                                </div>
                                            </div>
                                        ))}
                                    </div>
                                </div>
                            </div>
                        )}
                    </div>
                </div>
            </div>
        ))}
    </div>

    {/* Lightbox Modal */}
    <div id="lightbox-modal" class="lightbox-modal">
        <span class="lightbox-close">&times;</span>
        <div class="lightbox-box">
            <img class="lightbox-content" id="lightbox-img" src="" alt="Enlarged view" />
            <div id="lightbox-caption" class="lightbox-caption"></div>
        </div>
    </div>
</section>

<script is:inline>
  // Tab selector & Lightbox script
  document.addEventListener('DOMContentLoaded', () => {
    // --- Tab Selection ---
    const section = document.querySelector('.events-section');
    if (section) {
      const buttons = section.querySelectorAll('.event-tab-btn');
      buttons.forEach(btn => {
        btn.addEventListener('click', () => {
          const targetId = btn.getAttribute('data-event-id');
          
          buttons.forEach(b => b.classList.remove('active'));
          btn.classList.add('active');
          
          const panels = section.querySelectorAll('.event-panel');
          panels.forEach(panel => {
            panel.classList.remove('active');
            if (panel.id === `panel-${targetId}`) {
              panel.classList.add('active');
            }
          });
        });
      });
    }

    // --- Lightbox Modal ---
    const modal = document.getElementById('lightbox-modal');
    const modalImg = document.getElementById('lightbox-img');
    const modalCaption = document.getElementById('lightbox-caption');
    const closeBtn = document.querySelector('.lightbox-close');

    if (modal && modalImg) {
      // Setup image click listeners for flyer cards and photo cards
      document.querySelectorAll('.photo-card img, .flyer-card img').forEach(img => {
        img.addEventListener('click', () => {
          modal.classList.add('active');
          modalImg.src = img.src;
          modalImg.alt = img.alt;
          if (modalCaption) {
            modalCaption.textContent = img.alt || "";
          }
        });
      });

      // Close handlers
      if (closeBtn) {
        closeBtn.addEventListener('click', () => {
          modal.classList.remove('active');
        });
      }

      modal.addEventListener('click', (e) => {
        if (e.target === modal || e.target === closeBtn) {
          modal.classList.remove('active');
        }
      });

      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && modal.classList.contains('active')) {
          modal.classList.remove('active');
        }
      });
    }
  });
</script>

<style>
    .events-section {
        padding-bottom: 80px;
    }

    .events-hero {
        position: relative;
        height: 200px;
        background-size: cover;
        background-position: center;
        display: flex;
        justify-content: center;
        align-items: center;
        overflow: hidden;
        padding-bottom: 20px;
        padding-top: 60px;
    }
    .events-hero-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(180deg, rgba(34, 110, 147, 0.2) 0%, rgba(34, 110, 147, 0.4) 100%);
        z-index: 1;
    }
    .events-hero-content {
        position: relative;
        z-index: 2;
        text-align: center;
    }
    .events-hero h1 {
        font-family: 'Lora', serif;
        font-size: 48px;
        font-weight: 500;
        color: white;
        text-shadow: 0 2px 10px rgba(0,0,0,0.15);
        letter-spacing: 0.5px;
    }

    /* Tabs Navigation */
    .events-nav-container {
        display: flex;
        justify-content: center;
        margin-top: 40px;
        margin-bottom: 20px;
        padding: 0 20px;
    }
    .events-tabs-nav {
        background: rgba(255, 255, 255, 0.85);
        backdrop-filter: blur(16px);
        padding: 6px;
        border-radius: 30px;
        display: inline-flex;
        gap: 4px;
        border: 1px solid rgba(255, 255, 255, 0.7);
        box-shadow: 0 10px 30px -10px rgba(34, 110, 147, 0.12);
    }
    .event-tab-btn {
        font-family: 'Inter', sans-serif;
        font-size: 11pt;
        font-weight: 500;
        color: #666666;
        background: transparent;
        border: none;
        padding: 10px 28px;
        border-radius: 25px;
        cursor: pointer;
        transition: all 0.35s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .event-tab-btn:hover {
        color: #226E93;
        background: rgba(34, 110, 147, 0.05);
    }
    .event-tab-btn.active {
        color: white;
        background: linear-gradient(135deg, #226E93 0%, #1e6c93 100%);
        box-shadow: 0 8px 16px -6px rgba(34, 110, 147, 0.4);
    }

    /* Event Panels */
    .container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 20px 24px;
    }
    .event-panel {
        display: none;
        opacity: 0;
    }
    .event-panel.active {
        display: block;
        animation: panelFadeIn 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }

    @keyframes panelFadeIn {
        from {
            opacity: 0;
            transform: translateY(16px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* Professional Grid (Left: Flyer & Info, Right: Media) */
    .event-main-grid {
        display: grid;
        grid-template-columns: 0.85fr 1.15fr; /* Left: 42.5%, Right: 57.5% */
        gap: 56px;
        align-items: start;
        margin-top: 20px;
    }

    /* Media Column (Right) */
    .event-media-col {
        display: flex;
        flex-direction: column;
        gap: 48px;
    }
    .media-title {
        font-family: 'Lora', serif;
        font-size: 22px;
        color: #226E93;
        font-weight: 500;
        border-bottom: 2px solid rgba(34, 110, 147, 0.15);
        padding-bottom: 12px;
        margin-bottom: 20px;
        letter-spacing: -0.2px;
    }

    /* Videos Styling */
    .videos-grid {
        display: flex;
        flex-direction: column;
        gap: 30px;
    }
    .video-card {
        background: #ffffff;
        border-radius: 16px;
        overflow: hidden;
        border: 1px solid rgba(0, 0, 0, 0.05);
        box-shadow: 0 12px 30px -10px rgba(0, 0, 0, 0.06);
        max-width: 580px; /* Video is kept neat and professional */
        width: 100%;
        transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .video-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 20px 40px -15px rgba(0, 0, 0, 0.08);
    }
    .iframe-wrapper {
        position: relative;
        width: 100%;
        padding-bottom: 56.25%; /* 16:9 aspect ratio */
        height: 0;
        overflow: hidden;
    }
    .iframe-wrapper iframe {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        border: none;
    }
    .video-wrapper {
        width: 100%;
        aspect-ratio: 16 / 9;
        overflow: hidden;
        background: #000000;
    }
    .local-video {
        width: 100%;
        height: 100%;
        display: block;
        object-fit: contain;
    }
    .video-caption {
        padding: 14px 20px;
        font-family: 'Inter', sans-serif;
        font-size: 10pt;
        font-weight: 500;
        color: #444444;
        text-align: center;
        background: #fafafa;
        border-top: 1px solid rgba(0,0,0,0.03);
    }

    /* Gallery Styling */
    .gallery-instruction {
        font-family: 'Inter', sans-serif;
        font-size: 9.5pt;
        color: #888888;
        margin-top: -12px;
        margin-bottom: 20px;
        font-style: italic;
    }
    .photo-grid-scroll {
        max-height: 520px;
        overflow-y: auto;
        padding-right: 12px;
    }
    .event-gallery-col.full-width .photo-grid-scroll {
        max-height: none;
        overflow-y: visible;
        padding-right: 0;
    }
    
    /* Scrollbar */
    .photo-grid-scroll::-webkit-scrollbar {
        width: 6px;
    }
    .photo-grid-scroll::-webkit-scrollbar-track {
        background: rgba(0, 0, 0, 0.02);
        border-radius: 4px;
    }
    .photo-grid-scroll::-webkit-scrollbar-thumb {
        background: rgba(34, 110, 147, 0.2);
        border-radius: 4px;
        transition: background 0.3s;
    }
    .photo-grid-scroll::-webkit-scrollbar-thumb:hover {
        background: rgba(34, 110, 147, 0.45);
    }

    .photo-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(130px, 1fr));
        gap: 16px;
    }
    
    .photo-card {
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.04);
        border: 1px solid rgba(255, 255, 255, 0.8);
        background: #ffffff;
        cursor: pointer;
    }
    .photo-card-inner {
        position: relative;
        width: 100%;
        padding-bottom: 75%; /* 4:3 Aspect Ratio */
        height: 0;
        overflow: hidden;
    }
    .photo-card img {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .photo-card:hover img {
        transform: scale(1.05);
    }

    /* Left Column (Flyer, Title, Info) */
    .event-info-col {
        display: flex;
        flex-direction: column;
    }
    
    /* Flyer Card (Top of Left Column) */
    .flyer-card {
        border-radius: 16px;
        overflow: hidden;
        border: 1px solid rgba(255, 255, 255, 0.6);
        box-shadow: 0 20px 40px -20px rgba(0, 0, 0, 0.12);
        background: #ffffff;
        margin-bottom: 40px;
        max-width: 100%;
        cursor: pointer;
    }
    .flyer-card-inner {
        position: relative;
        width: 100%;
        overflow: hidden;
    }
    .flyer-card img {
        display: block;
        width: 100%;
        height: auto;
        max-height: 520px;
        object-fit: contain;
        transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .flyer-card:hover img {
        transform: scale(1.02);
    }

    /* Details Card */
    .details-text-card {
        background: rgba(255, 255, 255, 0.45);
        backdrop-filter: blur(12px);
        padding: 36px;
        border-radius: 20px;
        border: 1px solid rgba(255, 255, 255, 0.5);
        box-shadow: 0 20px 40px -20px rgba(34, 110, 147, 0.06);
    }
    .event-title {
        font-family: 'Lora', serif;
        font-size: 36px;
        font-weight: 500;
        color: #226E93;
        line-height: 1.2;
        margin-bottom: 6px;
        letter-spacing: -0.5px;
    }
    .event-subtitle {
        font-family: 'Lora', serif;
        font-size: 18px;
        font-style: italic;
        color: #666666;
        margin-bottom: 28px;
        font-weight: 400;
    }
    
    /* Metadata Box */
    .event-metadata {
        display: flex;
        flex-direction: column;
        gap: 20px;
        margin-bottom: 32px;
        padding-bottom: 30px;
        border-bottom: 1px solid rgba(0, 0, 0, 0.06);
    }
    .meta-item {
        display: flex;
        align-items: center;
        gap: 16px;
    }
    .icon-wrapper {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: rgba(34, 110, 147, 0.08);
        display: flex;
        align-items: center;
        justify-content: center;
        color: #226E93;
        flex-shrink: 0;
    }
    .meta-icon {
        width: 20px;
        height: 20px;
    }
    .meta-text {
        display: flex;
        flex-direction: column;
    }
    .meta-label {
        font-family: 'Inter', sans-serif;
        font-size: 8.5pt;
        text-transform: uppercase;
        letter-spacing: 0.8px;
        color: #888888;
        font-weight: 600;
        line-height: 1.2;
        margin-bottom: 2px;
    }
    .meta-val {
        font-family: 'Inter', sans-serif;
        font-size: 10.5pt;
        font-weight: 500;
        color: #333333;
    }
    .event-description {
        font-family: var(--font-serif);
        font-size: 13.5pt;
        line-height: 1.8;
        color: #3c3c3c;
    }

    /* Lightbox Modal */
    .lightbox-modal {
        display: none;
        position: fixed;
        z-index: 9999;
        left: 0;
        top: 0;
        width: 100%;
        height: 100%;
        background-color: rgba(18, 18, 18, 0.95);
        backdrop-filter: blur(12px);
        align-items: center;
        justify-content: center;
    }
    .lightbox-modal.active {
        display: flex;
    }
    .lightbox-box {
        position: relative;
        display: flex;
        flex-direction: column;
        align-items: center;
        max-width: 90%;
        max-height: 90vh;
    }
    .lightbox-content {
        max-width: 100%;
        max-height: 80vh;
        object-fit: contain;
        border-radius: 8px;
        box-shadow: 0 10px 50px rgba(0,0,0,0.8);
        transform: scale(0.95);
        transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .lightbox-modal.active .lightbox-content {
        transform: scale(1);
    }
    .lightbox-caption {
        font-family: 'Inter', sans-serif;
        font-size: 11pt;
        color: rgba(255, 255, 255, 0.8);
        margin-top: 16px;
        text-align: center;
    }
    .lightbox-close {
        position: absolute;
        top: 20px;
        right: 30px;
        color: #ffffff;
        font-size: 44px;
        font-weight: 200;
        cursor: pointer;
        user-select: none;
        transition: color 0.3s, transform 0.3s;
        z-index: 10000;
    }
    .lightbox-close:hover {
        color: #49aad4;
        transform: scale(1.1);
    }

    /* Mobile Responsive styles */
    @media (max-width: 960px) {
        .event-main-grid {
            grid-template-columns: 1fr;
            gap: 48px;
        }
        .event-info-col {
            grid-row: 1; /* Poster and info at the top on mobile */
        }
        .event-media-col {
            grid-row: 2; /* Videos and images at the bottom on mobile */
        }
        .flyer-card img {
            max-height: 480px;
        }
        .event-title {
            font-size: 28px;
        }
        .photo-grid-scroll {
            max-height: none;
            overflow-y: visible;
            padding-right: 0;
        }
        .photo-grid {
            grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
        }
        .photo-card img {
            height: 125px;
        }
    }

    @media (max-width: 600px) {
        .container {
            padding: 15px 16px;
        }
        .event-tab-btn {
            padding: 8px 20px;
            font-size: 10pt;
        }
        .details-text-card {
            padding: 24px;
        }
        .event-metadata {
            padding-bottom: 20px;
        }
        .event-description {
            font-size: 12pt;
        }
        .lightbox-close {
            top: 15px;
            right: 20px;
            font-size: 30px;
        }
    }
</style>
