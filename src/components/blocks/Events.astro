---
const { title, events = [], color = "#2A7396" } = Astro.props;
const resolvePath = (p) => p && p.startsWith('/') ? `${import.meta.env.BASE_URL.replace(/\/$/, '')}${p}` : p;
const bgImage = resolvePath("/assets/hero_music_banner.png");
---
<section class="events-section">
    <div class="events-hero" style={`background-image: url(${bgImage}); background-color: ${color};`}>
        <div class="events-hero-overlay"></div>
        <div class="events-hero-content">
            <h1>{title || "Events"}</h1>
        </div>
    </div>

    {events.length > 0 && (
        <div class="events-nav-container">
            <div class="events-tabs-nav">
                {events.map((event, index) => (
                    <button 
                        class={`event-tab-btn ${index === 0 ? 'active' : ''}`}
                        data-event-id={event.id}
                    >
                        {event.title}
                    </button>
                ))}
            </div>
        </div>
    )}

    <div class="container">
        {events.map((event, index) => (
            <div 
                id={`panel-${event.id}`} 
                class={`event-panel ${index === 0 ? 'active' : ''}`}
            >
                <div class="event-details-grid">
                    {/* Left Column - Flyer */}
                    <div class="event-flyer-col">
                        <div class="flyer-card">
                            <img src={resolvePath(event.flyerImage)} alt={`${event.title} Flyer`} />
                        </div>
                    </div>

                    {/* Right Column - Info */}
                    <div class="event-info-col">
                        <h2 class="event-title">{event.title}</h2>
                        {event.subtitle && <p class="event-subtitle">{event.subtitle}</p>}
                        
                        <div class="event-metadata">
                            <div class="meta-item">
                                <svg class="meta-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                                    <line x1="16" y1="2" x2="16" y2="6"></line>
                                    <line x1="8" y1="2" x2="8" y2="6"></line>
                                    <line x1="3" y1="10" x2="21" y2="10"></line>
                                </svg>
                                <span>{event.date}</span>
                            </div>
                            
                            {event.time && (
                                <div class="meta-item">
                                    <svg class="meta-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <circle cx="12" cy="12" r="10"></circle>
                                        <polyline points="12 6 12 12 16 14"></polyline>
                                    </svg>
                                    <span>{event.time}</span>
                                </div>
                            )}

                            {event.location && (
                                <div class="meta-item">
                                    <svg class="meta-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                                        <circle cx="12" cy="10" r="3"></circle>
                                    </svg>
                                    <span>{event.location}</span>
                                </div>
                            )}
                        </div>

                        {event.description && (
                            <div class="event-description">
                                <p>{event.description}</p>
                            </div>
                        )}
                    </div>
                </div>

                {/* Media Row - Video on Left, Gallery on Right */}
                {((event.videos && event.videos.length > 0) || (event.gallery && event.gallery.length > 0)) && (
                    <div class="event-media-row">
                        {/* Videos (Left Column - 40% Width) */}
                        {event.videos && event.videos.length > 0 && (
                            <div class={`event-videos-col ${(!event.gallery || event.gallery.length === 0) ? 'full-width' : ''}`}>
                                <h3 class="media-title">Videos & Performances</h3>
                                <div class="videos-grid">
                                    {event.videos.map((vid) => {
                                        const videoId = vid.videoUrl.includes('v=') 
                                            ? vid.videoUrl.split('v=')[1].split('&')[0] 
                                            : vid.videoUrl.split('/').pop();
                                        return (
                                            <div class="video-card">
                                                <div class="iframe-wrapper">
                                                    <iframe 
                                                        src={`https://www.youtube.com/embed/${videoId}`} 
                                                        title={vid.title || "YouTube video player"} 
                                                        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" 
                                                        allowfullscreen>
                                                    </iframe>
                                                </div>
                                                {vid.title && <p class="video-caption">{vid.title}</p>}
                                            </div>
                                        );
                                    })}
                                </div>
                            </div>
                        )}

                        {/* Gallery (Right Column - 60% Width) */}
                        {event.gallery && event.gallery.length > 0 && (
                            <div class={`event-gallery-col ${(!event.videos || event.videos.length === 0) ? 'full-width' : ''}`}>
                                <h3 class="media-title">Event Gallery</h3>
                                <div class="photo-grid-scroll">
                                    <div class="photo-grid">
                                        {event.gallery.map((img) => (
                                            <div class="photo-card">
                                                <img 
                                                    src={resolvePath(img.src)} 
                                                    alt={img.alt || "Event gallery photo"} 
                                                    loading="lazy"
                                                />
                                            </div>
                                        ))}
                                    </div>
                                </div>
                            </div>
                        )}
                    </div>
                )}
            </div>
        ))}
    </div>

    {/* Lightbox Modal */}
    <div id="lightbox-modal" class="lightbox-modal">
        <span class="lightbox-close">&times;</span>
        <img class="lightbox-content" id="lightbox-img" src="" alt="Enlarged view" />
    </div>
</section>

<script is:inline>
  // Tab selector & Lightbox script
  document.addEventListener('DOMContentLoaded', () => {
    // --- Tab Selection ---
    const section = document.querySelector('.events-section');
    if (section) {
      const buttons = section.querySelectorAll('.event-tab-btn');
      buttons.forEach(btn => {
        btn.addEventListener('click', () => {
          const targetId = btn.getAttribute('data-event-id');
          
          buttons.forEach(b => b.classList.remove('active'));
          btn.classList.add('active');
          
          const panels = section.querySelectorAll('.event-panel');
          panels.forEach(panel => {
            panel.classList.remove('active');
            if (panel.id === `panel-${targetId}`) {
              panel.classList.add('active');
            }
          });
        });
      });
    }

    // --- Lightbox Modal ---
    const modal = document.getElementById('lightbox-modal');
    const modalImg = document.getElementById('lightbox-img');
    const closeBtn = document.querySelector('.lightbox-close');

    if (modal && modalImg) {
      // Setup image click listeners
      document.querySelectorAll('.photo-card img, .flyer-card img').forEach(img => {
        img.style.cursor = 'zoom-in';
        img.addEventListener('click', () => {
          modal.classList.add('active');
          modalImg.src = img.src;
          modalImg.alt = img.alt;
        });
      });

      // Close handlers
      if (closeBtn) {
        closeBtn.addEventListener('click', () => {
          modal.classList.remove('active');
        });
      }

      modal.addEventListener('click', (e) => {
        if (e.target === modal || e.target === closeBtn) {
          modal.classList.remove('active');
        }
      });

      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && modal.classList.contains('active')) {
          modal.classList.remove('active');
        }
      });
    }
  });
</script>

<style>
    .events-section {
        padding-bottom: 60px;
    }

    .events-hero {
        position: relative;
        height: 180px;
        background-size: cover;
        background-position: center;
        display: flex;
        justify-content: center;
        align-items: center;
        overflow: hidden;
        padding-bottom: 32px;
        padding-top: 60px;
    }
    .events-hero-overlay {
        position: absolute;
        inset: 0;
        background: rgba(34, 110, 147, 0.15);
        z-index: 1;
    }
    .events-hero-content {
        position: relative;
        z-index: 2;
        text-align: center;
    }
    .events-hero h1 {
        font-family: 'Lora', serif;
        font-size: 45pt;
        font-weight: 400;
        color: white;
        line-height: 1.1;
    }

    /* Tabs Navigation */
    .events-nav-container {
        display: flex;
        justify-content: center;
        margin-top: 40px;
        margin-bottom: 10px;
        padding: 0 20px;
    }
    .events-tabs-nav {
        background: rgba(255, 255, 255, 0.7);
        backdrop-filter: blur(10px);
        padding: 6px;
        border-radius: 30px;
        display: inline-flex;
        gap: 6px;
        border: 1px solid rgba(255, 255, 255, 0.5);
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.04);
    }
    .event-tab-btn {
        font-family: 'Inter', sans-serif;
        font-size: 11pt;
        font-weight: 500;
        color: #555555;
        background: transparent;
        border: none;
        padding: 10px 24px;
        border-radius: 25px;
        cursor: pointer;
        transition: all 0.35s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .event-tab-btn:hover {
        color: #226E93;
        background: rgba(34, 110, 147, 0.06);
    }
    .event-tab-btn.active {
        color: white;
        background: #226E93;
        box-shadow: 0 4px 10px rgba(34, 110, 147, 0.2);
    }

    /* Event Panels */
    .container {
        max-width: 1100px;
        margin: 0 auto;
        padding: 20px 32px;
    }
    .event-panel {
        display: none;
        opacity: 0;
    }
    .event-panel.active {
        display: block;
        animation: panelFadeIn 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }

    @keyframes panelFadeIn {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* 2-Column Grid */
    .event-details-grid {
        display: grid;
        grid-template-columns: 1.1fr 1.3fr;
        gap: 48px;
        align-items: start;
        margin-top: 10px;
        margin-bottom: 40px;
    }

    /* Left Column - Flyer Card */
    .event-flyer-col {
        display: flex;
        justify-content: center;
    }
    .flyer-card {
        border-radius: 12px;
        overflow: hidden;
        border: 1px solid rgba(255, 255, 255, 0.4);
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
        transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.5s cubic-bezier(0.16, 1, 0.3, 1);
        background: #fff;
    }
    .flyer-card:hover {
        transform: translateY(-4px) scale(1.01);
        box-shadow: 0 15px 40px rgba(0, 0, 0, 0.12);
    }
    .flyer-card img {
        display: block;
        width: 100%;
        max-height: 650px;
        height: auto;
        object-fit: contain;
    }

    /* Right Column - Info */
    .event-info-col {
        padding-top: 10px;
    }
    .event-title {
        font-family: 'Lora', serif;
        font-size: 32pt;
        font-weight: 500;
        color: #226E93;
        line-height: 1.15;
        margin-bottom: 8px;
    }
    .event-subtitle {
        font-family: 'Lora', serif;
        font-size: 16pt;
        font-style: italic;
        color: #666666;
        margin-bottom: 24px;
        font-weight: 400;
    }
    .event-metadata {
        display: flex;
        flex-direction: column;
        gap: 16px;
        margin-bottom: 30px;
        background: rgba(255, 255, 255, 0.5);
        backdrop-filter: blur(5px);
        padding: 20px;
        border-radius: 8px;
        border: 1px solid rgba(255, 255, 255, 0.3);
    }
    .meta-item {
        display: flex;
        align-items: center;
        gap: 12px;
        font-family: 'Inter', sans-serif;
        font-size: 11pt;
        color: #444444;
    }
    .meta-icon {
        width: 20px;
        height: 20px;
        color: #226E93;
        flex-shrink: 0;
    }
    .event-description {
        font-family: var(--font-serif);
        font-size: 12.5pt;
        line-height: 1.75;
        color: #333333;
    }

    /* Media Sections - Side-by-Side (40% Video, 60% Gallery) */
    .event-media-row {
        margin-top: 60px;
        border-top: 1px solid rgba(0, 0, 0, 0.06);
        padding-top: 40px;
        display: grid;
        grid-template-columns: 4fr 6fr; /* Video 40%, Gallery 60% */
        gap: 40px;
        align-items: start;
    }
    .media-title {
        font-family: 'Lora', serif;
        font-size: 20pt;
        color: #226E93;
        margin-bottom: 24px;
        font-weight: 400;
    }

    /* Videos Column (Left) */
    .event-videos-col.full-width {
        grid-column: span 2;
    }
    .videos-grid {
        display: flex;
        flex-direction: column;
        gap: 24px;
    }
    .video-card {
        background: white;
        border-radius: 10px;
        overflow: hidden;
        border: 1px solid rgba(0,0,0,0.05);
        box-shadow: 0 4px 15px rgba(0,0,0,0.04);
        max-width: 100%;
    }
    .iframe-wrapper {
        position: relative;
        width: 100%;
        padding-bottom: 56.25%; /* 16:9 Aspect Ratio */
        height: 0;
        overflow: hidden;
    }
    .iframe-wrapper iframe {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        border: none;
    }
    .video-caption {
        padding: 14px;
        font-family: 'Inter', sans-serif;
        font-size: 10pt;
        color: #555555;
        text-align: center;
        background: #fafafa;
        border-top: 1px solid rgba(0,0,0,0.03);
    }

    /* Gallery Column (Right) */
    .event-gallery-col.full-width {
        grid-column: span 2;
    }
    
    /* Scrollable gallery to match video height and prevent long scrolls */
    .photo-grid-scroll {
        max-height: 400px;
        overflow-y: auto;
        padding-right: 8px;
    }
    .event-gallery-col.full-width .photo-grid-scroll {
        max-height: none;
        overflow-y: visible;
        padding-right: 0;
    }
    
    /* Styled Scrollbar */
    .photo-grid-scroll::-webkit-scrollbar {
        width: 6px;
    }
    .photo-grid-scroll::-webkit-scrollbar-track {
        background: rgba(0,0,0,0.03);
        border-radius: 4px;
    }
    .photo-grid-scroll::-webkit-scrollbar-thumb {
        background: rgba(34, 110, 147, 0.25);
        border-radius: 4px;
    }
    .photo-grid-scroll::-webkit-scrollbar-thumb:hover {
        background: rgba(34, 110, 147, 0.45);
    }

    .photo-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(130px, 1fr));
        gap: 12px;
    }
    .event-gallery-col.full-width .photo-grid {
        grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
        gap: 20px;
    }
    
    .photo-card {
        border-radius: 8px;
        overflow: hidden;
        box-shadow: 0 4px 15px rgba(0,0,0,0.05);
        border: 1px solid rgba(255,255,255,0.4);
        background: #fff;
        transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .photo-card:hover {
        transform: scale(1.03);
    }
    .photo-card img {
        display: block;
        width: 100%;
        height: 100px;
        object-fit: cover;
        transition: opacity 0.3s;
    }
    .photo-card img:hover {
        opacity: 0.9;
    }
    .event-gallery-col.full-width .photo-card img {
        height: 150px;
    }

    /* Lightbox Modal */
    .lightbox-modal {
        display: none;
        position: fixed;
        z-index: 9999;
        padding-top: 50px;
        left: 0;
        top: 0;
        width: 100%;
        height: 100%;
        background-color: rgba(18, 18, 18, 0.95);
        backdrop-filter: blur(8px);
        align-items: center;
        justify-content: center;
    }
    .lightbox-modal.active {
        display: flex;
    }
    .lightbox-content {
        margin: auto;
        display: block;
        max-width: 90%;
        max-height: 82vh;
        object-fit: contain;
        border-radius: 8px;
        box-shadow: 0 10px 40px rgba(0,0,0,0.6);
        transform: scale(0.95);
        transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .lightbox-modal.active .lightbox-content {
        transform: scale(1);
    }
    .lightbox-close {
        position: absolute;
        top: 20px;
        right: 30px;
        color: #ffffff;
        font-size: 36px;
        font-weight: 300;
        cursor: pointer;
        user-select: none;
        transition: color 0.3s;
    }
    .lightbox-close:hover {
        color: #49aad4;
    }

    /* Mobile Responsive styles */
    @media (max-width: 900px) {
        .event-details-grid {
            grid-template-columns: 1fr;
            gap: 32px;
        }
        .flyer-card img {
            max-height: 500px;
        }
        .event-title {
            font-size: 24pt;
        }
        .event-media-row {
            grid-template-columns: 1fr;
            gap: 32px;
        }
        .event-videos-col, .event-gallery-col {
            grid-column: span 1;
        }
        .photo-grid-scroll {
            max-height: none;
            overflow-y: visible;
            padding-right: 0;
        }
        .photo-grid {
            grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
        }
        .photo-card img {
            height: 140px;
        }
    }

    @media (max-width: 600px) {
        .container {
            padding: 15px 16px;
        }
        .event-tab-btn {
            padding: 8px 16px;
            font-size: 10pt;
        }
        .event-metadata {
            padding: 15px;
        }
        .event-description {
            font-size: 11.5pt;
        }
        .lightbox-close {
            top: 15px;
            right: 20px;
            font-size: 30px;
        }
    }
</style>
