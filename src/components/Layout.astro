---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "SAPTA | Student Artists' Platform",
  description = "SAPTA is a non-profit, student-led organization that promotes Carnatic music. While providing students of all levels opportunities to perform, they also have a way to showcase their talents in unique ways.",
} = Astro.props;

const resolvePath = (p: string) =>
  p.startsWith('/') ? `${import.meta.env.BASE_URL.replace(/\/$/, '')}${p}` : p;

const path = Astro.url.pathname.replace(/\/$/, '') || '/';

const isActive = (href: string) => {
  if (href === '/') return path === '/';
  return path === href || path.startsWith(href + '/');
};
---
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    <meta name="description" content={description}>
    <link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,500;0,700;1,400&family=Gentium+Basic:ital,wght@0,400;0,700;1,400&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <style>
        :root {
            --sapta-teal: #226E93;
            --sapta-teal-dark: #1e6c93;
            --text-main: rgba(33,33,33,1);
            --font-serif: 'Gentium Basic', serif;
            --font-heading: 'Lora', serif;
        }

        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: var(--font-serif);
            background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
            background-attachment: fixed;
            color: var(--text-main);
            line-height: 1.6667;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        /* ===================== */
        /* TOP NAVIGATION        */
        /* ===================== */
        header {
            background: #ffffff;
            position: sticky;
            top: 0;
            z-index: 1000;
            border-bottom: 1px solid #f0f0f0;
            height: 70px;
            display: flex;
            align-items: center;
        }
        nav {
            max-width: 1200px;
            width: 100%;
            margin: 0 auto;
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0 20px;
        }
        .nav-logo {
            display: flex;
            align-items: center;
            gap: 12px;
            text-decoration: none;
        }
        .nav-logo img {
            height: 36px;
            border-radius: 4px;
        }
        .nav-logo span {
            font-family: var(--font-heading);
            font-size: 16pt;
            color: #333333;
            font-weight: 500;
            letter-spacing: 0.5px;
        }
        .nav-links {
            list-style: none;
            display: flex;
            gap: 24px;
            align-items: center;
        }
        .nav-links > li > a,
        .nav-links .dropdown-label {
            font-family: 'Inter', sans-serif;
            font-size: 10.5pt;
            color: #555555;
            font-weight: 500;
            text-decoration: none;
            cursor: pointer;
            transition: color 0.4s cubic-bezier(0.16, 1, 0.3, 1);
            position: relative;
            padding: 8px 0;
            display: block;
        }
        .nav-links > li > a::after {
            content: '';
            position: absolute;
            width: 100%;
            height: 2px;
            bottom: 0;
            left: 0;
            background-color: #226E93;
            transform: scaleX(0);
            transform-origin: bottom right;
            transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
        }
        .nav-links > li > a:hover,
        .nav-links .dropdown:hover .dropdown-label {
            color: #226E93;
        }
        .nav-links > li > a:hover::after,
        .nav-links > li > a.active::after {
            transform: scaleX(1);
            transform-origin: bottom left;
        }
        .nav-links > li > a.active {
            color: #226E93;
        }

        /* Hamburger Menu */
        .hamburger {
            display: none;
            flex-direction: column;
            gap: 6px;
            background: none;
            border: none;
            cursor: pointer;
            padding: 8px;
        }
        .hamburger span {
            width: 24px;
            height: 2px;
            background-color: #555555;
            transition: all 0.3s ease;
            display: block;
        }
        .hamburger.active span:nth-child(1) {
            transform: rotate(45deg) translate(10px, 10px);
        }
        .hamburger.active span:nth-child(2) {
            opacity: 0;
        }
        .hamburger.active span:nth-child(3) {
            transform: rotate(-45deg) translate(7px, -7px);
        }

        /* Dropdowns */
        .dropdown {
            position: relative;
        }
        .dropdown-label::after {
            content: ' ▾';
            font-size: 0.8em;
            vertical-align: middle;
        }
        .dropdown-label.active {
            color: #226E93;
        }
        .dropdown-menu {
            display: none;
            position: absolute;
            background: #ffffff;
            min-width: 180px;
            top: 100%;
            right: 0;
            padding: 8px 0;
            box-shadow: 0 4px 16px rgba(0,0,0,0.08);
            border: 1px solid #e0e0e0;
            border-radius: 4px;
            list-style: none;
            z-index: 1010;
        }
        .dropdown-menu li a {
            display: block;
            padding: 10px 20px;
            font-family: 'Inter', sans-serif;
            font-size: 9.5pt;
            color: #444444;
            text-decoration: none;
            transition: background 0.2s, color 0.2s;
        }
        .dropdown-menu li a:hover,
        .dropdown-menu li a.active {
            background: #f5f5f5;
            color: #226E93;
        }
        .dropdown:hover .dropdown-menu {
            display: block;
        }

        /* Mobile-specific dropdown behavior */
        .dropdown-label {
            user-select: none;
        }
        .dropdown.active .dropdown-menu {
            display: block;
        }

        /* ===================== */
        /* MOBILE RESPONSIVENESS */
        /* ===================== */
        @media (max-width: 768px) {
            header {
                height: auto;
                padding: 12px 0;
            }
            nav {
                padding: 0 16px;
            }
            .nav-logo span {
                font-size: 14pt;
            }
            .hamburger {
                display: flex;
            }
            .nav-links {
                position: absolute;
                top: 70px;
                left: 0;
                right: 0;
                background: #ffffff;
                flex-direction: column;
                gap: 0;
                align-items: stretch;
                padding: 12px 0;
                max-height: 0;
                overflow: hidden;
                transition: max-height 0.3s ease;
                box-shadow: 0 8px 16px rgba(0,0,0,0.08);
                border-bottom: 1px solid #f0f0f0;
            }
            .nav-links.active {
                max-height: 500px;
            }
            .nav-links > li {
                border-bottom: 1px solid #f0f0f0;
            }
            .nav-links > li > a,
            .nav-links .dropdown-label {
                display: block;
                padding: 14px 20px;
                font-size: 10pt;
            }
            .nav-links > li > a::after {
                display: none;
            }
            .nav-links > li > a:hover {
                background: #f5f5f5;
            }
            .dropdown-menu {
                position: static;
                box-shadow: none;
                border: none;
                background: #f9f9f9;
                min-width: auto;
                max-height: 0;
                overflow: hidden;
                transition: max-height 0.3s ease;
            }
            .dropdown.active .dropdown-menu {
                max-height: 200px;
            }
            .dropdown-menu li a {
                padding: 12px 40px;
                font-size: 9.5pt;
            }
            .dropdown-label::after {
                display: inline-block;
                margin-left: 8px;
                transition: transform 0.3s ease;
            }
            .dropdown.active .dropdown-label::after {
                transform: rotate(180deg);
            }
        }

        @media (max-width: 480px) {
            nav {
                padding: 0 12px;
            }
            .nav-logo span {
                font-size: 12pt;
            }
            .nav-links > li > a,
            .nav-links .dropdown-label {
                padding: 12px 16px;
                font-size: 9.5pt;
            }
            .dropdown-menu li a {
                padding: 10px 32px;
            }
            footer {
                padding: 24px 16px;
                font-size: 11pt;
            }
            footer h3 {
                font-size: 13pt;
            }
            footer p {
                font-size: 10pt;
            }
        }

        /* ===================== */
        /* MAIN CONTENT          */
        /* ===================== */
        main {
            flex: 1;
            animation: pageFadeIn 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        }
        @keyframes pageFadeIn {
            from { opacity: 0; transform: translateY(12px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        /* ===================== */
        /* SCROLL REVEALS        */
        /* ===================== */
        .reveal {
            opacity: 0;
            transform: translateY(35px) scale(0.985);
            transition: opacity 1.3s cubic-bezier(0.16, 1, 0.3, 1), transform 1.3s cubic-bezier(0.16, 1, 0.3, 1);
        }
        .reveal-left { transform: translate(-30px, 20px) scale(0.985); }
        .reveal-right { transform: translate(30px, 20px) scale(0.985); }
        .reveal.visible { opacity: 1; transform: translate(0) scale(1); }

        /* ===================== */
        /* FOOTER                */
        /* ===================== */
        footer {
            background-color: #212121;
            color: rgba(255,255,255,0.87);
            padding: 32px 48px;
            font-family: var(--font-heading);
            font-size: 12pt;
        }
        footer h3 {
            font-size: 15pt;
            font-weight: 400;
            margin-bottom: 8px;
            color: rgba(73, 170, 212, 1);
        }
        footer p {
            font-family: var(--font-serif);
            font-size: 11pt;
            color: rgba(255,255,255,0.6);
        }
    </style>
</head>
<body>

    <header>
        <nav>
            <a href={resolvePath('/')} class="nav-logo">
                <img src={resolvePath("/assets/image_186b79.png")} alt="SAPTA Logo">
                <span>SAPTA</span>
            </a>
            <button class="hamburger" aria-label="Toggle menu">
                <span></span>
                <span></span>
                <span></span>
            </button>
            <ul class="nav-links">
                <li><a href={resolvePath('/')} class={isActive('/') ? 'active' : ''}>About Us</a></li>
                <li class="dropdown">
                    <span class={`dropdown-label ${isActive('/events') ? 'active' : ''}`}>Events</span>
                    <ul class="dropdown-menu">
                        <li><a href={resolvePath('/events')} class={isActive('/events') ? 'active' : ''}>All Events</a></li>
                        <li><a href={resolvePath('/events/go-rakshana')} class={isActive('/events/go-rakshana') ? 'active' : ''}>Go Rakshana</a></li>
                    </ul>
                </li>
                <li><a href={resolvePath('/feedback')} class={isActive('/feedback') ? 'active' : ''}>Feedback Form</a></li>
                <li class="dropdown">
                    <span class={`dropdown-label ${isActive('/registration') ? 'active' : ''}`}>Registration</span>
                    <ul class="dropdown-menu">
                        <li><a href={resolvePath('/registration/spotlight')} class={isActive('/registration/spotlight') ? 'active' : ''}>Sapta Spotlight</a></li>
                        <li><a href={resolvePath('/registration/group')} class={isActive('/registration/group') ? 'active' : ''}>Group Registration</a></li>
                    </ul>
                </li>
                <li class="dropdown">
                    <span class={`dropdown-label ${isActive('/media') ? 'active' : ''}`}>Media</span>
                    <ul class="dropdown-menu">
                        <li><a href={resolvePath('/media/past')} class={isActive('/media/past') ? 'active' : ''}>Past Events</a></li>
                        <li><a href={resolvePath('/media/videos')} class={isActive('/media/videos') ? 'active' : ''}>Videos/Performances</a></li>
                    </ul>
                </li>
            </ul>
        </nav>
    </header>

    <main>
        <slot />
    </main>

    <footer>
        <h3>Contact Us</h3>
        <p>Email: artssapta@gmail.com</p>
    </footer>

    <script is:inline>
        function initScrollReveal() {
            const reveals = document.querySelectorAll('.reveal:not(.visible)');
            const observer = new IntersectionObserver((entries, obs) => {
                let delay = 0;
                const intersecting = entries
                    .filter(e => e.isIntersecting)
                    .sort((a, b) => a.target.getBoundingClientRect().top - b.target.getBoundingClientRect().top);
                intersecting.forEach(entry => {
                    const el = entry.target;
                    obs.unobserve(el);
                    setTimeout(() => el.classList.add('visible'), delay);
                    delay += 100;
                });
            }, { threshold: 0.04, rootMargin: '0px 0px -30px 0px' });
            reveals.forEach(el => observer.observe(el));
        }

        function initMobileMenu() {
            const hamburger = document.querySelector('.hamburger');
            const navLinks = document.querySelector('.nav-links');
            const dropdowns = document.querySelectorAll('.dropdown');

            hamburger?.addEventListener('click', () => {
                hamburger.classList.toggle('active');
                navLinks?.classList.toggle('active');
            });

            // Close menu when a link is clicked
            navLinks?.addEventListener('click', (e) => {
                if (e.target.tagName === 'A') {
                    hamburger?.classList.remove('active');
                    navLinks?.classList.remove('active');
                }
            });

            // Handle dropdown toggles on mobile
            dropdowns.forEach(dropdown => {
                const label = dropdown.querySelector('.dropdown-label');
                label?.addEventListener('click', (e) => {
                    if (window.innerWidth <= 768) {
                        e.preventDefault();
                        e.stopPropagation();
                        dropdown.classList.toggle('active');
                    }
                });
            });

            // Close dropdowns when menu closes
            window.addEventListener('resize', () => {
                if (window.innerWidth > 768) {
                    hamburger?.classList.remove('active');
                    navLinks?.classList.remove('active');
                    dropdowns.forEach(d => d.classList.remove('active'));
                }
            });
        }

        document.addEventListener('DOMContentLoaded', () => {
            initScrollReveal();
            initMobileMenu();
        });
    </script>

</body>
</html>
