---
import { getEntry } from 'astro:content';
import Layout from '../components/Layout.astro';
import GoogleForm from '../components/blocks/GoogleForm.astro';
import Hero from '../components/blocks/Hero.astro';
import TextBlock from '../components/blocks/TextBlock.astro';

const page = await getEntry('pages', 'feedback');
const blocks = page?.data?.blocks || [];

const components = {
  hero: Hero,
  'google-form': GoogleForm,
  text: TextBlock,
};
---
<Layout title="Feedback | SAPTA">
    {blocks.map((block) => {
        const Component = components[block.type];
        return Component ? <Component {...block} /> : null;
    })}
</Layout>
